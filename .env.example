# =====================================================================
# Farmsky — Environment configuration
# ---------------------------------------------------------------------
# 1. Copy this file to ".env"   ->   cp .env.example .env
# 2. Fill in the values below (especially the M-Pesa Daraja keys).
# 3. Restart the server.
#
# If the M-Pesa keys are LEFT BLANK, the app runs in SIMULATION mode:
# STK push "succeeds" instantly so you can demo the full flow without
# real money. Fill the keys in to switch to LIVE M-Pesa payments.
# =====================================================================

# ---- Server ----
# Port the Node server listens on (AWS: 8080 is convenient behind Nginx/ALB)
PORT=8080
# PostgreSQL connection string
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5432/farmsky
# Optional: set to require when your PostgreSQL host enforces SSL
PGSSLMODE=disable


# =====================================================================
# M-PESA DARAJA (STK PUSH) CREDENTIALS
# =====================================================================
# STK Push is used in TWO places in Farmsky:
#   (a) CASH checkout — the buyer pays the full price on the spot, and
#   (b) PAY LATER (Murabaha) repayments — installment payments.
# Both flows send the same Daraja STK Push prompt to the customer's phone.
#
# SANDBOX (testing) QUICK START — already pre-filled below:
#   * The Shortcode (174379), Passkey and MPESA_ENV=sandbox are the
#     Safaricom SANDBOX defaults. To test STK push, just paste your own
#     sandbox Consumer Key + Secret (step 1-3) and leave the rest as-is.
#   * If you leave Consumer Key/Secret BLANK, payments run in SIMULATION
#     mode (no Daraja call) so you can still demo the whole checkout.
#
# WHERE TO GET THESE (step by step):
#
#  1. Go to  https://developer.safaricom.co.ke  and create a free account.
#  2. Log in -> click "My Apps" -> "Add a new App".
#       - Give it any name (e.g. "Farmsky").
#       - Tick the "Lipa Na M-Pesa Sandbox" product.
#       - Click "CREATE APP".
#  3. Open the app you just created. You will see two values:
#       - "Consumer Key"     ->  copy into MPESA_CONSUMER_KEY below
#       - "Consumer Secret"  ->  copy into MPESA_CONSUMER_SECRET below
#  4. Get the Passkey + Shortcode:
#       - In the left menu open  "APIs" -> "M-Pesa Express" (a.k.a. STK Push)
#         -> "Simulate".
#       - The page shows a test "Business ShortCode" (sandbox default: 174379)
#         ->  copy into MPESA_SHORTCODE below
#       - It also shows the "Lipa Na Mpesa Online Passkey" (a long string)
#         ->  copy into MPESA_PASSKEY below
#         (Sandbox default passkey:
#          bfb279f9aa9bdbcf158e97dd71a467cd2e0c893059b10f78e6b72ada1ed2c919)
#  5. MPESA_ENV: keep "sandbox" for testing. Change to "production" ONLY
#     after Safaricom approves a real Paybill/Till and gives you the
#     production Consumer Key/Secret/Passkey/Shortcode (a "Go Live" step).
#  6. MPESA_CALLBACK_URL: must be a PUBLIC https URL that Safaricom can
#     reach. Set it to:  https://YOUR-DOMAIN/api/mpesa/callback
#     (For local testing you can use an ngrok https URL.)
#
# SANDBOX TEST PHONE: use 2547XXXXXXXX test numbers. In the sandbox the
# STK prompt is auto-approved with PIN you enter; no real money moves.
# ---------------------------------------------------------------------

MPESA_CONSUMER_KEY=kpfj2cZVUbkCJQu2zCrtK1wUNC4RosEUNZqAoI1eNvKHgQUp
MPESA_CONSUMER_SECRET=5yS7SkfOCQmOcxGUMl3QlCAejFSA6B21sQieVSGqSWyPACNdxNSEseCaPoMZLLrC
MPESA_SHORTCODE=174379
MPESA_PASSKEY=bfb279f9aa9bdbcf158e97dd71a467cd2e0c893059b10f78e6b72ada1ed2c919
MPESA_ENV=sandbox
MPESA_CALLBACK_URL=https://feed.farmsky.africa/api/mpesa/callback


# =====================================================================
# SMS OTP PROVIDER  —  TALKSASA  (https://talksasa.com)
# =====================================================================
# Farmsky sends a 6-digit OTP by SMS for customer SIGN-UP and PASSWORD
# RESET. The default provider is TalkSASA Bulk SMS, sent FROM a
# Safaricom-registered Sender Name (NameID).
#
# WHERE TO GET THESE (step by step):
#   1. Log in to https://bulksms.talksasa.com  (your TalkSASA account).
#   2. Open  "Developers"  ->  "API keys"  ->  generate / copy your API
#      token. Paste it into SMS_API_TOKEN below.
#   3. SMS_SENDER_ID = the Sender Name (NameID) that Safaricom approved
#      for you (e.g. "FARMSKY"). Max 11 characters. This is the name the
#      recipient sees as the sender.
#
# >>> AT DEPLOY TIME you normally only paste TWO things: <<<
#     SMS_API_TOKEN   = your TalkSASA API token
#     SMS_SENDER_ID   = your Safaricom-approved Sender Name (NameID)
#
# If SMS_API_TOKEN is LEFT BLANK the app runs in DEMO mode: the OTP is
# shown on screen so you can still test sign-up / reset end-to-end.
#
# ---- Provider (leave as "talksasa") ----
SMS_PROVIDER=talksasa
#
# ---- Required (paste from TalkSASA) ----
SMS_API_TOKEN=3565|gcmV8AZFYHB0J7fvDISVpwIMFrfBKwRDhdK2xH2Bba79e842
# Safaricom NameID / Sender Name (max 11 chars)
SMS_SENDER_ID=Farmsky
#
# ---- Optional ----
# Endpoint override. Leave blank to use the TalkSASA default:
#   https://bulksms.talksasa.com/api/v3/sms/send
SMS_API_URL=
#
# ADVANCED — only needed if you switch to a different/custom gateway:
#   SMS_PROVIDER=generic
#   SMS_API_URL=https://your-gateway/send
#   SMS_PHONE_FIELD=to            # field that carries the phone number
#   SMS_MESSAGE_FIELD=message     # field that carries the SMS text
#   SMS_BODY_TEMPLATE={"recipient":"{phone}","body":"{message}","from":"{sender}"}
SMS_PHONE_FIELD=
SMS_MESSAGE_FIELD=
SMS_BODY_TEMPLATE=


# =====================================================================
# EMAIL PROVIDER  —  RESEND  (https://resend.com)
# =====================================================================
# In the Admin -> Data Export page you can email a CSV report to any
# address. The default provider is Resend.
#
# WHERE TO GET THESE (step by step):
#   1. Sign in to https://resend.com  ->  "API Keys"  ->  "Create API
#      Key". Copy the key (starts with "re_") into EMAIL_API_TOKEN below.
#   2. EMAIL_FROM must be an address on a domain you've VERIFIED in
#      Resend ("Domains" tab). You may include a friendly name, e.g.
#      "Farmsky Reports <reports@yourdomain.com>".
#      (For quick tests Resend also allows "onboarding@resend.dev".)
#
# >>> AT DEPLOY TIME paste these TWO things from Resend: <<<
#     EMAIL_API_TOKEN = your Resend API key (re_xxxxxxxx)
#     EMAIL_FROM      = a verified from address
#
# If LEFT BLANK, the email-share button is disabled and Admins can still
# DOWNLOAD the report locally (CSV / Excel) — no email account required.
#
# ---- Provider (leave as "resend") ----
EMAIL_PROVIDER=resend
#
# ---- Required for email sharing (paste from Resend) ----
EMAIL_API_TOKEN=re_TtzXHjjb_9ds7ZJjeY29LpioTk27V3jZq
EMAIL_FROM=onboarding@resend.dev
#
# ---- Optional ----
# Endpoint override. Leave blank to use the Resend default:
#   https://api.resend.com/emails
# (Set EMAIL_PROVIDER=sendgrid + EMAIL_API_URL to use SendGrid instead.)
EMAIL_API_URL=

# ---- SasaPay (https://developer.sasapay.app/docs/getting-started) ----
SASAPAY_CLIENT_ID=
SASAPAY_CLIENT_SECRET=
SASAPAY_MERCHANT_CODE=
SASAPAY_ENV=sandbox
SASAPAY_CALLBACK_URL=https://your-domain.com/api/sasapay/callback

# ---- KCB Buni (https://buni.kcbgroup.com/getting-started) ----
BUNI_CLIENT_ID=
BUNI_CLIENT_SECRET=
BUNI_API_KEY=
BUNI_TILL_NUMBER=
BUNI_ENV=sandbox
BUNI_CALLBACK_URL=https://your-domain.com/api/buni/callback

# ---- Central Payment Gateway ----
# Per-app HMAC secrets used by the three marketplaces when they call this
# gateway. Each marketplace stores its own secret as an env var and signs
# every request with HMAC-SHA256 using the same secret stored in
# app_clients.hmac_secret on this server. Rotate via the DB.
#
# Endpoint URL the three apps will call:
#   POST https://equipment.farmsky.africa/api/v1/payments/initiate
#   GET  https://equipment.farmsky.africa/api/v1/payments/status/:transaction_ref
#
# These callback URLs go in the provider dashboards:
#   M-Pesa:   https://equipment.farmsky.africa/api/v1/payments/callbacks/mpesa
#   SasaPay:  https://equipment.farmsky.africa/api/v1/payments/callbacks/sasapay
#   Buni:     https://equipment.farmsky.africa/api/v1/payments/callbacks/buni
